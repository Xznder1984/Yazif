# Yazif Configuration
# Copy this file to .env and fill in your values

# NVIDIA NIM API Key (required for AI video naming)
# Get yours at: https://build.nvidia.com
NVIDIA_API_KEY=

# Default download path (can be changed in-app)
# DOWNLOAD_PATH=C:\Users\YourName\Downloads\Yazif

# Separate audio/video folders (true = AI sorts into audio/video subfolders)
SEPARATE_FOLDERS=true
