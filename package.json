{
  "name": "yazif",
  "version": "1.0.0",
  "description": "Yazif - A clean, modern YouTube downloader with Catppuccin theme",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "node scripts/build.js",
    "build:win": "node scripts/build.js && electron-builder --win",
    "dev": "node scripts/build.js && electron .",
    "start": "electron .",
    "typecheck": "tsc --noEmit"
  },
  "author": "Xander",
  "license": "MIT",
  "dependencies": {
    "music-metadata": "^11.14.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.yazif.downloader",
    "productName": "Yazif",
    "copyright": "Copyright © 2026 Xander",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      ".env"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "website/assets/icon.ico",
      "artifactName": "Yazif-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Yazif",
      "installerIcon": "website/assets/icon.ico",
      "uninstallerIcon": "website/assets/icon.ico",
      "installerHeaderIcon": "website/assets/icon.ico",
      "warningsAsErrors": false,
      "include": "scripts/installer.nsh",
      "artifactName": "Yazif-${version}-Setup.${ext}"
    },
    "portable": {
      "artifactName": "Yazif-${version}-Portable.${ext}"
    }
  }
}
