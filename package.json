{
  "name": "yazif",
  "version": "1.0.0",
  "description": "Yazif - A clean, modern YouTube downloader with Catppuccin theme",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "node scripts/build.js",
    "build:win": "node scripts/build.js && electron-builder --win",
    "dev": "node scripts/build.js && electron .",
    "start": "electron .",
    "typecheck": "tsc --noEmit"
  },
  "author": "Xander",
  "license": "MIT",
  "dependencies": {
    "music-metadata": "^11.14.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.yazif.downloader",
    "productName": "Yazif",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      ".env"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "website/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
